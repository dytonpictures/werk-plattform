# Ausschliesslich Entwicklungswerte. Nicht unveraendert produktiv verwenden.
WERK_ENV=development
WERK_PORT=3000
WERK_BUILD_VERSION=dev
WERK_BOOTSTRAP_ADMIN_PASSWORD=werk-development
WERK_IDENTITY_MFA_ENABLED=false
# Erforderlich bei MFA=true: `openssl rand -base64 32 | tr -d '='`
WERK_IDENTITY_MFA_KEY=
# Alternativ für Schlüsselrotation:
# WERK_IDENTITY_MFA_CURRENT_KEY_ID=current
# WERK_IDENTITY_MFA_KEYS=current:<Base64-32-Byte>,previous:<Base64-32-Byte>
WERK_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
POSTGRES_PASSWORD=change-this-development-password
POSTGRES_MIGRATOR_PASSWORD=change-this-migrator-password
POSTGRES_WORK_PASSWORD=change-this-work-runtime-password
POSTGRES_IDENTITY_PASSWORD=change-this-identity-runtime-password
POSTGRES_ADMIN_PASSWORD=change-this-admin-runtime-password
POSTGRES_SERVICE_PASSWORD=change-this-service-runtime-password
POSTGRES_WORKER_PASSWORD=change-this-worker-runtime-password
POSTGRES_BACKUP_PASSWORD=change-this-backup-password
