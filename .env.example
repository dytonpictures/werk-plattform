# Ausschliesslich Entwicklungswerte. Nicht unveraendert produktiv verwenden.
WERK_ENV=development
WERK_PORT=3000
WERK_BUILD_VERSION=dev
WERK_BOOTSTRAP_ADMIN_PASSWORD=werk-development
WERK_IDENTITY_MFA_ENABLED=false
# Erforderlich bei MFA=true: `openssl rand -base64 32 | tr -d '='`
WERK_IDENTITY_MFA_KEY=
# Alternativ für Schlüsselrotation:
# WERK_IDENTITY_MFA_CURRENT_KEY_ID=current
# WERK_IDENTITY_MFA_KEYS=current:<Base64-32-Byte>,previous:<Base64-32-Byte>
WERK_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Native API-Transportsicherheit. `disabled` ist nur fuer Entwicklung und Tests;
# Produktion verlangt `tls` oder `mtls`. Private Schluessel nie einchecken.
WERK_HTTP_TLS_MODE=disabled
# WERK_HTTP_TLS_CERT_FILE=/run/secrets/api-server.pem
# WERK_HTTP_TLS_KEY_FILE=/run/secrets/api-server-key.pem
# Nur fuer `mtls`:
# WERK_HTTP_TLS_CLIENT_CA_FILE=/run/secrets/platform-client-ca.pem
# Nur wenn HTTPS vor der API an einem Proxy terminiert wird. Ohne explizite
# Netze wird X-Forwarded-Proto nicht als Sicherheitsnachweis vertraut.
# WERK_HTTP_TRUSTED_PROXY_CIDRS=127.0.0.0/8,10.0.0.0/8
# Kafka ist im lokalen Compose-Stack enthalten. Produktion benoetigt TLS und
# SASL oder ein Client-Zertifikat; Secrets nicht in dieser Datei einchecken.
WERK_KAFKA_ENABLED=true
WERK_KAFKA_BROKERS=kafka:19092
WERK_KAFKA_DOMAIN_EVENTS_TOPIC=platform.domain-events.v1
WERK_KAFKA_SECURITY_AUDIT_TOPIC=platform.security-audit.v1
WERK_KAFKA_RUNTIME_LOGS_TOPIC=platform.runtime-logs.v1
WERK_KAFKA_TLS=false
WERK_KAFKA_SASL_MECHANISM=none
# WERK_KAFKA_SASL_USERNAME=
# WERK_KAFKA_SASL_PASSWORD=
# WERK_KAFKA_TLS_CA_FILE=/run/secrets/kafka-ca.pem
# WERK_KAFKA_TLS_CERT_FILE=/run/secrets/kafka-client.pem
# WERK_KAFKA_TLS_KEY_FILE=/run/secrets/kafka-client-key.pem
POSTGRES_PASSWORD=change-this-development-password
POSTGRES_MIGRATOR_PASSWORD=change-this-migrator-password
POSTGRES_WORK_PASSWORD=change-this-work-runtime-password
POSTGRES_IDENTITY_PASSWORD=change-this-identity-runtime-password
POSTGRES_ADMIN_PASSWORD=change-this-admin-runtime-password
POSTGRES_SERVICE_PASSWORD=change-this-service-runtime-password
POSTGRES_WORKER_PASSWORD=change-this-worker-runtime-password
POSTGRES_BACKUP_PASSWORD=change-this-backup-password
